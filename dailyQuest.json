      1.0,
      1.0,
      1.06,
      1.1,
      1.14,
      1.18,
      1.75
    ],
    "breakResetsToDay": 1,
    "loginBaseFormula": "clamp(round(5 + flipBrickCost * 0.52), 11, 58)",
    "todayFormula": "round(loginBase * dayMultipliers[streakDay - 1])",
    "tomorrowPreview": "今日领取后 streakDay+1；第7天领完次日为第1天；断签重置为第1天"
  },
