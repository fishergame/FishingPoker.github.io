{
  "version": "1.0.0",
  "description": "主城每日任务：登录连签（7日周期）+ 对战档位；数值随主城等级缩放",
  "scaleBy": "mainCityLevel",
  "flipBrickCostFormula": "12 + (mainCityLevel - 1) * 3",
